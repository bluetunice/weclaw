{
  "name": "weclaw-client",
  "version": "1.0.0",
  "description": "跨平台AI助手客户端，支持模型选择和工作区间安全控制",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run start:renderer\" \"wait-on tcp:3000 && npm run start:main\"",
    "start:renderer": "vite",
    "start:main": "electron .",
    "build": "tsc -p electron && vite build",
    "build:main": "tsc -p electron",
    "build:renderer": "vite build",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "keywords": [
    "electron",
    "ai",
    "desktop",
    "cross-platform"
  ],
  "author": "Claw Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@headlessui/react": "^1.0.0",
    "@heroicons/react": "^2.0.0",
    "@types/prismjs": "^1.26.6",
    "date-fns": "^2.30.0",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "zod": "^3.0.0"
  },
  "build": {
    "appId": "com.claw.client",
    "productName": "WeClaw Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
